{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "organizeImports": {
    "enabled": true
  },
  "files": {
    "ignore": [
      "**/dist",
      "**/node_modules",
      "**/coverage",
      "packages/codex-protocol/src/generated",
      "packages/codex-protocol/schema",
      "packages/testkit/fixtures",
      "pnpm-lock.yaml"
    ]
  }
}
