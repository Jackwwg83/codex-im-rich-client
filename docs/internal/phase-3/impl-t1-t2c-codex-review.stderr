   592	  CREATE TABLE callback_tokens (
   593	    token_hash       TEXT NOT NULL PRIMARY KEY,
   594	    approval_id      TEXT NOT NULL,
   595	    action           TEXT NOT NULL CHECK(action IN
   596	                       ('allow_once','allow_session','decline','abort')),
   597	    callback_nonce   TEXT NOT NULL,
   598	    target_platform   TEXT NOT NULL,
   599	  target_chat_id    TEXT NOT NULL,
