     1	// T2a (Phase 3) — openDatabase + standard pragmas.
     2	//
     3	// Plan: docs/internal/superpowers/plans/2026-05-02-phase-3-plan.md §16.2 T2a
     4	//       + §7 D38 (sync write-through; better-sqlite3 is sync by design)
     5	//       + §7 D39 (preflight-required; better-sqlite3 verified at T1.0)
     6	//
     7	// Returns a `better-sqlite3` Database handle with the project's standard
     8	// pragmas applied:
     9	//
    10	//   journal_mode = WAL
    11	//     Concurrent reader / single writer; faster writes than the default
    12	//     `delete` mode. SQLite's WAL is a no-op on `:memory:` databases —
    13	//     SQLite refuses the change and the journal stays in `memory` mode.
    14	//     Test below documents both branches.
    15	//
    16	//   foreign_keys = ON
    17	//     Enforces FK constraints. SQLite's default is OFF for backwards
    18	//     compatibility with old apps; we always want ON so FK violations
    19	//     fail at write time, not silently corrupt the schema.
    20	//
    21	// Sync API: better-sqlite3 is fully synchronous. This matches D38's
    22	// SessionRouter sync write-through contract and D33's per-callback
    23	// atomic CAS expectations. No `await` needed for any DB op.
    24	
    25	import Database from "better-sqlite3";
    26	
    27	/**
    28	 * Re-exported Database handle type. Consumers should import this from
    29	 * `@codex-im/storage-sqlite` rather than `better-sqlite3` directly so
    30	 * that swapping the SQLite binding (per D39 fallback path, e.g. to
    31	 * Node 24's built-in `node:sqlite`) only requires updating this
    32	 * single re-export.
    33	 */
    34	export type DatabaseHandle = Database.Database;
    35	
    36	/**
    37	 * Open a SQLite database with the project's standard pragmas.
    38	 *
    39	 * @param path Filesystem path to the SQLite file, or `":memory:"` for
    40	 *   an in-process database. The caller owns the path; this function
    41	 *   does NOT mkdir / chmod / clean up. Caller is responsible for
    42	 *   `db.close()` (or end-of-process cleanup).
    43	 *
    44	 * @returns The opened Database handle with `journal_mode = WAL` (when
    45	 *   path is a file) and `foreign_keys = ON` applied.
    46	 */
    47	export function openDatabase(path: string): DatabaseHandle {
    48	  const db = new Database(path);
    49	  // Order matters slightly: WAL pragma should fire before any tables
    50	  // are created so the WAL file exists alongside the main DB. For
    51	  // `:memory:` databases, SQLite ignores the WAL request and keeps
    52	  // `memory` mode; the tests document both branches.
    53	  db.pragma("journal_mode = WAL");
    54	  db.pragma("foreign_keys = ON");
    55	  return db;
    56	}

