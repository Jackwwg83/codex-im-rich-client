     1	// T2b + T2c (Phase 3) — runMigrations apply + idempotency.
     2	//
     3	// Plan: docs/internal/superpowers/plans/2026-05-02-phase-3-plan.md §16.2 T2b/T2c
     4	//
     5	// T2b — first-run apply: a migrations dir containing one `001-*.sql`
     6	//       file is applied on first run; both the migration's side-effect
     7	//       (a `foo` table appears) AND the schema_version audit row are
     8	//       visible after the call returns.
     9	//
    10	// T2c — idempotency: re-running runMigrations on the same dir applies
    11	//       nothing AND does not re-execute the migration body. We prove
    12	//       no re-execution by corrupting the migration file's contents
    13	//       between runs; if the runner re-read it, the invalid SQL would
    14	//       throw. We further assert applied_at invariance (no re-insert
    15	//       into schema_version).
    16	//
    17	// T3a will replace the synthetic fixtures with the real `001-init.sql`
    18	// once that migration ships. Synthetic filenames here match the
    19	// production convention `NNN-kebab.sql` so the runner's filter regex
    20	// is exercised.
    21	
    22	import { mkdtempSync, rmSync, writeFileSync } from "node:fs";
    23	import { tmpdir } from "node:os";
    24	import { join } from "node:path";
    25	import { afterEach, beforeEach, describe, expect, it } from "vitest";
    26	import { openDatabase, runMigrations } from "../src/database.js";
    27	
    28	describe("runMigrations first run (T2b)", () => {
    29	  let migDir: string;
    30	
    31	  beforeEach(() => {
    32	    migDir = mkdtempSync(join(tmpdir(), "codex-im-migrations-t2b-"));
    33	  });
    34	
    35	  afterEach(() => {
    36	    rmSync(migDir, { recursive: true, force: true });
    37	  });
    38	
    39	  it("applies a single migration and records it in schema_version", () => {
    40	    writeFileSync(join(migDir, "001-init.sql"), "CREATE TABLE foo (id INTEGER PRIMARY KEY);");
    41	
    42	    const db = openDatabase(":memory:");
    43	    try {
    44	      const result = runMigrations(db, migDir);
    45	
    46	      expect(result.applied).toEqual(["001-init.sql"]);
    47	
    48	      const fooTable = db
    49	        .prepare("SELECT name FROM sqlite_master WHERE type='table' AND name='foo'")
    50	        .get();
    51	      expect(fooTable).toEqual({ name: "foo" });
    52	
    53	      const versionRows = db.prepare("SELECT version FROM schema_version ORDER BY version").all();
    54	      expect(versionRows).toEqual([{ version: "001-init.sql" }]);
    55	    } finally {
    56	      db.close();
    57	    }
    58	  });
    59	
    60	  it("ignores files in the migrations dir that don't match NNN-kebab.sql", () => {
    61	    // README.md, .DS_Store, or human notes should not be treated as
    62	    // migrations. The filter regex enforces the prefix shape.
    63	    writeFileSync(join(migDir, "README.md"), "# notes\n");
    64	    writeFileSync(join(migDir, "scratch.sql"), "CREATE TABLE bad (x INT);");
    65	    writeFileSync(join(migDir, "001-init.sql"), "CREATE TABLE foo (id INTEGER PRIMARY KEY);");
    66	
    67	    const db = openDatabase(":memory:");
    68	    try {
    69	      const result = runMigrations(db, migDir);
    70	      expect(result.applied).toEqual(["001-init.sql"]);
    71	
    72	      const bad = db
    73	        .prepare("SELECT name FROM sqlite_master WHERE type='table' AND name='bad'")
    74	        .get();
    75	      expect(bad).toBeUndefined();
    76	    } finally {
    77	      db.close();
    78	    }
    79	  });
    80	
    81	  it("applies multiple migrations in numeric (lexicographic) order", () => {
    82	    writeFileSync(join(migDir, "002-add-bar.sql"), "CREATE TABLE bar (id INTEGER PRIMARY KEY);");
    83	    writeFileSync(join(migDir, "001-init.sql"), "CREATE TABLE foo (id INTEGER PRIMARY KEY);");
    84	
    85	    const db = openDatabase(":memory:");
    86	    try {
    87	      const result = runMigrations(db, migDir);
    88	      expect(result.applied).toEqual(["001-init.sql", "002-add-bar.sql"]);
    89	
    90	      const versions = db
    91	        .prepare("SELECT version FROM schema_version ORDER BY applied_at, version")
    92	        .all();
    93	      expect(versions).toEqual([{ version: "001-init.sql" }, { version: "002-add-bar.sql" }]);
    94	    } finally {
    95	      db.close();
    96	    }
    97	  });
    98	});
    99	
   100	describe("runMigrations idempotency (T2c)", () => {
   101	  let migDir: string;
   102	
   103	  beforeEach(() => {
   104	    migDir = mkdtempSync(join(tmpdir(), "codex-im-migrations-t2c-"));
   105	  });
   106	
   107	  afterEach(() => {
   108	    rmSync(migDir, { recursive: true, force: true });
   109	  });
   110	
   111	  it("re-running applies nothing and does not re-execute the migration body", () => {
   112	    const migPath = join(migDir, "001-init.sql");
   113	    writeFileSync(migPath, "CREATE TABLE foo (id INTEGER PRIMARY KEY);");
   114	
   115	    const db = openDatabase(":memory:");
   116	    try {
   117	      // First run: applies the migration, records it.
   118	      const first = runMigrations(db, migDir);
   119	      expect(first.applied).toEqual(["001-init.sql"]);
   120	
   121	      const firstRow = db
   122	        .prepare("SELECT version, applied_at FROM schema_version WHERE version = ?")
   123	        .get("001-init.sql") as { version: string; applied_at: number };
   124	      expect(firstRow.version).toBe("001-init.sql");
   125	
   126	      // Corrupt the migration file. If the runner re-reads or re-executes
   127	      // the body on the second call, SQLite will throw a syntax error and
   128	      // the test fails. The pass condition is therefore proof that the
   129	      // runner skipped the file purely on filename match against
   130	      // schema_version — exactly the idempotency contract T2c demands.
   131	      writeFileSync(migPath, "THIS IS NOT VALID SQL ;;;");
   132	
   133	      // Second run: must be a no-op.
   134	      const second = runMigrations(db, migDir);
   135	      expect(second.applied).toEqual([]);
   136	
   137	      // schema_version row count is unchanged AND applied_at was NOT
   138	      // overwritten (no INSERT/UPDATE happened against the recorded row).
   139	      const allRows = db
   140	        .prepare("SELECT version, applied_at FROM schema_version ORDER BY version")
   141	        .all();
   142	      expect(allRows).toEqual([{ version: "001-init.sql", applied_at: firstRow.applied_at }]);
   143	
   144	      // The first-run side-effect (the `foo` table) is still there.
   145	      const fooTable = db
   146	        .prepare("SELECT name FROM sqlite_master WHERE type='table' AND name='foo'")
   147	        .get();
   148	      expect(fooTable).toEqual({ name: "foo" });
   149	    } finally {
   150	      db.close();
   151	    }
   152	  });
   153	});

