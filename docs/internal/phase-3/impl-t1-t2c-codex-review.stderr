     9	import { readFileSync, readdirSync, statSync } from "node:fs";
    10	import { join } from "node:path";
    11	import { describe, expect, it } from "vitest";
    12	
    13	const SRC_DIR = "packages/channel-core/src";
    14	
    15	const FORBIDDEN_ALL = ["@codex-im/app-server-client", "@codex-im/protocol"];
    16	
    17	function listTsFiles(root: string): string[] {
    18	  const out: string[] = [];
    19	  for (const name of readdirSync(root)) {
    20	    const full = join(root, name);
    21	    if (statSync(full).isDirectory()) {
    22	      out.push(...listTsFiles(full));
    23	    } else if (full.endsWith(".ts")) {
    24	      out.push(full);
    25	    }
    26	  }
    27	  return out;
    28	}
    29	
    30	function findAnyImports(needle: string): string[] {
    31	  const matches: string[] = [];
    32	  for (const file of listTsFiles(SRC_DIR)) {
    33	    const lines = readFileSync(file, "utf-8").split("\n");
    34	    for (let i = 0; i < lines.length; i += 1) {
    35	      const line = lines[i] ?? "";
    36	      if (!/^\s*import\b/.test(line)) continue;
    37	      if (!line.includes(needle)) continue;
    38	      matches.push(`${file}:${i + 1}: ${line.trim()}`);
    39	    }
    40	  }
    41	  return matches;
    42	}
    43	
    44	describe("channel-core boundary: no protocol imports anywhere (T18 / F13)", () => {
