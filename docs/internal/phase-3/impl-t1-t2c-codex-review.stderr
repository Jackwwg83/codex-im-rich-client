     1	// T2a (Phase 3) — pragma verification for openDatabase.
     2	//
     3	// Plan: docs/internal/superpowers/plans/2026-05-02-phase-3-plan.md §16.2 T2a
     4	//
     5	// Single failing test target: openDatabase applies WAL + foreign_keys
     6	// pragmas. Two scenarios documented:
     7	//   - file-backed: WAL takes effect (journal_mode = wal)
     8	//   - :memory:: WAL is silently rejected by SQLite; mode stays
     9	//     `memory`. foreign_keys still applies.
    10	//
    11	// Both scenarios MUST have foreign_keys = 1 (the integer SQLite
    12	// returns for the boolean ON state).
    13	
    14	import { mkdtempSync, rmSync } from "node:fs";
    15	import { tmpdir } from "node:os";
    16	import { join } from "node:path";
    17	import { afterEach, beforeEach, describe, expect, it } from "vitest";
    18	import { openDatabase } from "../src/database.js";
    19	
    20	describe("openDatabase pragmas (T2a)", () => {
    21	  let tmpDir: string;
    22	
    23	  beforeEach(() => {
    24	    tmpDir = mkdtempSync(join(tmpdir(), "codex-im-storage-t2a-"));
    25	  });
    26	
    27	  afterEach(() => {
    28	    rmSync(tmpDir, { recursive: true, force: true });
    29	  });
    30	
    31	  it("file-backed db: journal_mode=wal + foreign_keys=on", () => {
    32	    const dbPath = join(tmpDir, "t2a.db");
    33	    const db = openDatabase(dbPath);
    34	    try {
    35	      const journal = db.pragma("journal_mode", { simple: true });
    36	      expect(journal).toBe("wal");
    37	
    38	      const fk = db.pragma("foreign_keys", { simple: true });
    39	      expect(fk).toBe(1);
    40	    } finally {
    41	      db.close();
    42	    }
    43	  });
    44	
    45	  it(":memory: db: journal_mode falls back to memory; foreign_keys=on still applies", () => {
    46	    const db = openDatabase(":memory:");
    47	    try {
    48	      // SQLite refuses WAL for in-memory databases — the journal
    49	      // stays at the default `memory` mode. We document this so a
    50	      // future implementer doesn't try to "fix" the test by forcing
    51	      // WAL on `:memory:`.
    52	      const journal = db.pragma("journal_mode", { simple: true });
    53	      expect(journal).toBe("memory");
    54	
    55	      const fk = db.pragma("foreign_keys", { simple: true });
    56	      expect(fk).toBe(1);
    57	    } finally {
    58	      db.close();
    59	    }
