     1	// T1.1 (Phase 3) — boundary test: storage-sqlite has NO runtime
     2	// imports from upper-layer packages.
     3	//
     4	// Plan: docs/internal/superpowers/plans/2026-05-02-phase-3-plan.md §16.2 T1.1
     5	//       + §7 D27 (storage-sqlite is below core; no upward deps)
     6	//
     7	// Mirrors `packages/channel-core/test/no-broker-import.test.ts`
     8	// pattern. Filesystem walk over `packages/storage-sqlite/src/`,
     9	// scanning every .ts file for runtime imports of disallowed packages.
    10	// Type-only imports (`import type {...}`) are allowed since they're
    11	// stripped by the TypeScript transformer at build time and never
    12	// reach the JS bundle.
    13	//
    14	// Forbidden runtime imports — every package above storage-sqlite in
    15	// the Phase 3 layer cake:
    16	//   @codex-im/core               broker / redact / audit
    17	//   @codex-im/codex-runtime      runtime / EventNormalizer
    18	//   @codex-im/channel-core       adapter contract (Phase 2 closed)
    19	//   @codex-im/render             rich-block rendering
    20	//   @codex-im/daemon             top-level orchestration
    21	//   @codex-im/im-telegram        Phase 3 platform adapter (when added)
    22	
    23	import { readFileSync, readdirSync, statSync } from "node:fs";
    24	import { join } from "node:path";
    25	import { describe, expect, it } from "vitest";
    26	
    27	const SRC_DIR = "packages/storage-sqlite/src";
    28	
    29	const FORBIDDEN_RUNTIME = [
    30	  "@codex-im/core",
    31	  "@codex-im/codex-runtime",
    32	  "@codex-im/channel-core",
    33	  "@codex-im/render",
    34	  "@codex-im/daemon",
    35	  "@codex-im/im-telegram",
    36	];
    37	
    38	function listTsFiles(root: string): string[] {
    39	  const out: string[] = [];
    40	  for (const name of readdirSync(root)) {
    41	    const full = join(root, name);
    42	    if (statSync(full).isDirectory()) {
    43	      out.push(...listTsFiles(full));
    44	    } else if (full.endsWith(".ts")) {
    45	      out.push(full);
    46	    }
    47	  }
    48	  return out;
    49	}
    50	
    51	function findRuntimeImports(needle: string): string[] {
    52	  const matches: string[] = [];
    53	  for (const file of listTsFiles(SRC_DIR)) {
    54	    const lines = readFileSync(file, "utf-8").split("\n");
    55	    for (let i = 0; i < lines.length; i += 1) {
    56	      const line = lines[i] ?? "";
    57	      // Only flag lines that:
    58	      //   1. start with `import` (not inside a comment / string), AND
    59	      //   2. reference the forbidden package, AND
    60	      //   3. are NOT type-only (`import type {...}`).
    61	      if (!/^\s*import\b/.test(line)) continue;
    62	      if (!line.includes(needle)) continue;
    63	      if (/^\s*import\s+type\b/.test(line)) continue;
    64	      matches.push(`${file}:${i + 1}: ${line.trim()}`);
    65	    }
    66	  }
    67	  return matches;
    68	}
    69	
    70	describe("storage-sqlite boundary: no runtime imports from upper layers (T1.1 / D27)", () => {
    71	  for (const needle of FORBIDDEN_RUNTIME) {
    72	    it(`storage-sqlite src has no runtime import from ${needle}`, () => {
    73	      const matches = findRuntimeImports(needle);
    74	      expect(matches).toEqual([]);
    75	    });
    76	  }
    77	});

