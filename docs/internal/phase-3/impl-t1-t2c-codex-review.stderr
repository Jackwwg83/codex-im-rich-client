   601	  target_topic_id   TEXT,
   602	    actor_kind       TEXT NOT NULL CHECK(actor_kind IN ('im','system')),
   603	    actor_user_id    TEXT,
   604	    actor_platform   TEXT,
   605	    actor_reason     TEXT,
   606	    msg_chat_id      TEXT,
   607	    msg_message_id   TEXT,
   608	    status           TEXT NOT NULL CHECK(status IN
   609	                       ('issued','bound','used','expired','revoked')),
