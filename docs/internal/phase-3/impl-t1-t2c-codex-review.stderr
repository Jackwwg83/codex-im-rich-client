    29	
    30	function listTsFiles(root: string): string[] {
    31	  const out: string[] = [];
    32	  for (const name of readdirSync(root)) {
    33	    const full = join(root, name);
    34	    if (statSync(full).isDirectory()) {
    35	      out.push(...listTsFiles(full));
    36	    } else if (full.endsWith(".ts")) {
    37	      out.push(full);
    38	    }
    39	  }
    40	  return out;
    41	}
    42	
    43	function findAnyImports(needle: string): string[] {
    44	  const matches: string[] = [];
    45	  for (const file of listTsFiles(SRC_DIR)) {
    46	    const lines = readFileSync(file, "utf-8").split("\n");
    47	    for (let i = 0; i < lines.length; i += 1) {
    48	      const line = lines[i] ?? "";
    49	      if (!/^\s*import\b/.test(line)) continue;
    50	      if (!line.includes(needle)) continue;
