    70	/**
    71	 * Result of `runMigrations`. `applied` lists the filenames of migrations
    72	 * that were applied during *this* call, in the order they ran. An empty
    73	 * array means every migration on disk was already recorded in
    74	 * `schema_version` (the steady-state idempotent case).
    75	 */
    76	export interface MigrationRunResult {
    77	  applied: string[];
    78	}
    79	
    80	/**
    81	 * Bootstrap DDL for the `schema_version` audit table. T3a adds an explicit
    82	 * `001-init.sql` that owns this table; the runner installs it idempotently
    83	 * here so T2b's tests work without depending on T3a's file existing yet.
    84	 *
    85	 * Both this DDL and the T3a migration use `CREATE TABLE IF NOT EXISTS` so
    86	 * the redundancy is safe and self-documenting.
    87	 */
    88	const SCHEMA_VERSION_DDL = `
    89	  CREATE TABLE IF NOT EXISTS schema_version (
    90	    version    TEXT    PRIMARY KEY NOT NULL,
    91	    applied_at INTEGER NOT NULL
    92	  )
    93	`;
    94	
    95	/**
    96	 * Migration filename convention: `NNN-kebab-name.sql` where NNN is a
    97	 * zero-padded 3-digit ordinal. Lexicographic sort of the matching names
    98	 * is identical to numeric sort for as long as we stay under 1000
    99	 * migrations (Phase 3 plan §8.1 ships 7).
   100	 */
   101	const MIGRATION_FILE_RE = /^\d{3}-[a-z0-9-]+\.sql$/;
   102	
   103	/**
   104	 * Apply every `.sql` migration in `dir` that has not yet been recorded
   105	 * in `schema_version`, in filename order. Each file runs inside a
   106	 * transaction together with its `schema_version` insert, so a failed
   107	 * migration leaves both the schema AND the version table untouched.
   108	 *
   109	 * @param db   An open `DatabaseHandle` (typically from `openDatabase`).
   110	 * @param dir  Path to a directory containing migration files matching
   111	 *             `NNN-kebab-name.sql`. Other entries are ignored. Caller
   112	 *             owns the directory; the runner does NOT create it.
   113	 *
   114	 * @returns `{applied}` — filenames of migrations applied this call.
   115	 *          Empty when nothing was new (T2c idempotency).
   116	 */
   117	export function runMigrations(db: DatabaseHandle, dir: string): MigrationRunResult {
   118	  // Idempotent bootstrap so we can record what we apply.
   119	  db.exec(SCHEMA_VERSION_DDL);
   120	
   121	  const files = readdirSync(dir)
   122	    .filter((name) => MIGRATION_FILE_RE.test(name))
   123	    .sort();
   124	
   125	  const alreadyApplied = new Set(
   126	    (
   127	      db.prepare("SELECT version FROM schema_version").all() as {
   128	        version: string;
   129	      }[]
   130	    ).map((row) => row.version),
   131	  );
   132	
   133	  const insertVersion = db.prepare(
   134	    "INSERT INTO schema_version (version, applied_at) VALUES (?, ?)",
   135	  );
   136	
   137	  // better-sqlite3 wraps the inner function in a SAVEPOINT, so SQL
   138	  // failure inside `apply` rolls back BOTH the migration body AND the
   139	  // schema_version insert atomically.
   140	  const apply = db.transaction((file: string, sql: string) => {
   141	    db.exec(sql);
   142	    insertVersion.run(file, Date.now());
   143	  });
   144	
   145	  const applied: string[] = [];
   146	  for (const file of files) {
   147	    if (alreadyApplied.has(file)) continue;
   148	    const sql = readFileSync(join(dir, file), "utf8");
   149	    apply(file, sql);
   150	    applied.push(file);
   151	  }
   152	
   153	  return { applied };
   154	}

