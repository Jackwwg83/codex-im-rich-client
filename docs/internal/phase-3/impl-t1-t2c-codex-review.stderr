     8	// pattern. Storage's surface should never reference JsonRpcRequest,
     9	// ServerRequest, ApprovalUiAction, or any other protocol/core type:
    10	//   - The action column stores `'allow_once' | 'allow_session' |
    11	//     'decline' | 'abort'` as plain TEXT (D34 schema CHECK), not the
    12	//     ApprovalUiAction discriminated-union type from core.
    13	//   - The target columns store {platform, chatId, threadKey?, topicId?}
    14	//     as 4 explicit TEXT columns (D34 hydration contract from v2.4),
    15	//     not the Target type from core.
    16	//
    17	// Type-only imports are FORBIDDEN here (unlike no-core-import) because
    18	// even the type leak would couple storage to core's API surface and
    19	// invite implementers to share types instead of keeping storage's
    20	// schema as the source of truth.
    21	
    22	import { readFileSync, readdirSync, statSync } from "node:fs";
