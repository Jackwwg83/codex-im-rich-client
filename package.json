{
  "name": "codex-im-rich-client",
  "version": "0.1.0-phase7",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10 <11"
  },
  "packageManager": "pnpm@10.33.2",
  "codexIm": {
    "codexVersion": "0.128.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "better-sqlite3", "esbuild"]
  },
  "scripts": {
    "test": "vitest run --config vitest.config.ts --project unit --project contract",
    "test:unit": "vitest run --config vitest.config.ts --project unit",
    "test:contract": "vitest run --config vitest.config.ts --project contract",
    "test:cli-smoke": "vitest run --config vitest.config.ts --project cli-smoke",
    "test:all": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "pnpm -r typecheck",
    "typecheck:tests": "tsc -p tsconfig.test.json --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check:codex-version": "node scripts/check-codex-version.mjs",
    "check:all": "bash scripts/ci-check.sh",
    "protocol:generate": "pnpm check:codex-version && rm -rf packages/codex-protocol/src/generated packages/codex-protocol/schema && codex app-server generate-ts --out packages/codex-protocol/src/generated && codex app-server generate-json-schema --out packages/codex-protocol/schema && node scripts/canonicalize-schema.mjs",
    "protocol:check": "pnpm protocol:generate && git diff --exit-code packages/codex-protocol",
    "bridge:build": "tsx scripts/build-daemon-bundle.mts",
    "bridge:install": "node bin/install-bridge.mjs",
    "bridge:uninstall": "node bin/uninstall-bridge.mjs",
    "release:check": "tsx scripts/release-readiness-check.mts",
    "launchd:prepare": "node bin/prepare-launchd-runtime.mjs",
    "launchd:install": "node bin/install-launchd.mjs",
    "launchd:status": "node bin/launchd-status.mjs",
    "launchd:uninstall": "node bin/uninstall-launchd.mjs",
    "im:doctor": "tsx scripts/channels-doctor.mts",
    "channels:doctor": "pnpm im:doctor",
    "dingtalk:readiness": "tsx scripts/dingtalk-readiness.mts",
    "db:backup": "tsx packages/cli/src/index.ts db backup",
    "smoke:app-server": "tsx packages/cli/src/index.ts smoke app-server",
    "smoke:dingtalk-fake": "vitest run --config vitest.config.ts --project unit packages/daemon/test/dingtalk-fake-smoke.test.ts",
    "smoke:dingtalk-live": "tsx packages/im-dingtalk/scripts/live-smoke.mts",
    "smoke:computer-use-live": "tsx scripts/computer-use-live-smoke.mts",
    "smoke:lark-fake": "vitest run --config vitest.config.ts --project unit packages/daemon/test/lark-fake-smoke.test.ts",
    "smoke:lark-live": "tsx packages/im-lark/scripts/live-smoke.mts",
    "smoke:slack-live": "tsx packages/im-slack/scripts/live-smoke.mts",
    "daemon:run": "tsx packages/cli/src/index.ts daemon run",
    "smoke:telegram-fake": "tsx packages/cli/src/index.ts smoke telegram-fake",
    "smoke:daemon-roundtrip": "tsx packages/cli/src/index.ts smoke daemon-roundtrip",
    "smoke:telegram-live": "tsx packages/cli/src/index.ts smoke telegram-live",
    "smoke:telegram-live-roundtrip": "tsx packages/cli/src/index.ts smoke telegram-live-roundtrip",
    "smoke:telegram-side-by-side": "tsx packages/cli/src/index.ts smoke telegram-side-by-side",
    "smoke:telegram-real": "tsx packages/cli/src/index.ts smoke telegram-real",
    "smoke:real-turn": "tsx packages/cli/src/index.ts smoke real-turn",
    "runtime:send": "tsx packages/cli/src/index.ts runtime send"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.27.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  }
}
